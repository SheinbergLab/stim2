#!/bin/sh

set -e

# Refresh dynamic lib cache for libs installed with package.
ldconfig

# Determine platform-appropriate stim2 service
ARCH=$(dpkg --print-architecture)
if [ "$ARCH" = "arm64" ]; then
    STIM2_SVC=stim2.service
    STIM2_SVC_NAME=stim2
else
    STIM2_SVC=stim2-x11.service
    STIM2_SVC_NAME=stim2-x11
fi

# Detect first install vs upgrade (postinst is called as `postinst configure <old-version>`)
FIRST_INSTALL=0
if [ "$1" = "configure" ] && [ -z "$2" ]; then
    FIRST_INSTALL=1
fi

# Render the stim2-agent components configuration with the platform's actual
# unit name. The agent uses comp.Service to restart the right unit after a
# component update and to whitelist start/stop/restart via its API. Re-rendered
# on every configure so upgrades pick up template changes.
mkdir -p /etc/stim2-agent
if [ -f /usr/local/stim2/config/components.json ]; then
    sed "s|\"service\": \"stim2\"|\"service\": \"$STIM2_SVC_NAME\"|g" \
        /usr/local/stim2/config/components.json \
        > /etc/stim2-agent/components.json
fi

# Note: the agent runs unauthenticated by default to keep the bundled web UI
# working (its WebSocket client doesn't carry a Bearer token). If you want
# auth on this box, drop a DSERV_AGENT_TOKEN=... line into /etc/stim2-agent/env
# (mode 600) and restart stim2-agent -- the EnvironmentFile=- in the unit
# makes the file optional, so its presence enables auth. To turn auth back
# off, remove /etc/stim2-agent/env and restart stim2-agent; clients then need
# no token (and the bundled web UI's tokenless WebSocket works again). Note
# dservctl reads its own token from ~/.dservctl / DSERV_AGENT_TOKEN, so clear
# those too when disabling auth to avoid a stale mismatch.

# Ensure the 'stim' system user exists on X11-based systems. Runs on every
# configure (idempotent) so upgrades from hand-crafted installs pick it up too,
# which is what lets a later dpkg-reconfigure install the new User=stim unit
# without failing on a missing account.
if [ "$STIM2_SVC" = "stim2-x11.service" ]; then
    if ! getent passwd stim >/dev/null; then
        adduser --system --group --home /var/lib/stim \
            --shell /usr/sbin/nologin --gecos "stim2 stimulus presentation" stim
        echo "Created system user 'stim'"
    fi

    # Add stim to groups it needs to drive the display, input devices, and audio
    for grp in tty video input audio render; do
        if getent group "$grp" >/dev/null; then
            adduser stim "$grp" >/dev/null 2>&1 || true
        fi
    done

    # Ensure HOME exists with the right ownership (xinit writes .Xauthority here)
    mkdir -p /var/lib/stim
    chown stim:stim /var/lib/stim
fi

# Configure Xwrapper so the non-console 'stim' user can start the X server.
# Trixie ships allowed_users=console which blocks systemd-launched xinit.
# First install only -- never clobber admin edits on upgrade.
#
# We use debconf preseeding so xserver-xorg-legacy's own postinst writes
# allowed_users=Anybody. That value is package-owned and survives future
# xserver-xorg-legacy upgrades cleanly. needs_root_rights isn't exposed via
# debconf, so we sed-ensure it ourselves after dpkg-reconfigure runs.
if [ "$FIRST_INSTALL" = "1" ] && [ "$STIM2_SVC" = "stim2-x11.service" ]; then
    XWRAPPER=/etc/X11/Xwrapper.config
    mkdir -p /etc/X11
    if [ -f "$XWRAPPER" ] && [ ! -f "$XWRAPPER.stim2-bak" ]; then
        cp "$XWRAPPER" "$XWRAPPER.stim2-bak"
        echo "Backed up existing $XWRAPPER to $XWRAPPER.stim2-bak"
    fi

    if dpkg -s xserver-xorg-legacy >/dev/null 2>&1 \
       && command -v debconf-set-selections >/dev/null 2>&1; then
        echo "xserver-xorg-legacy xserver-xorg-legacy/xwrapper/allowed_users select Anybody" \
            | debconf-set-selections
        DEBIAN_FRONTEND=noninteractive dpkg-reconfigure -f noninteractive xserver-xorg-legacy
        echo "Set Xwrapper allowed_users=anybody via debconf"
    else
        # Fallback: write the file directly (xserver-xorg-legacy missing/old)
        printf 'allowed_users=anybody\n' > "$XWRAPPER"
        echo "Wrote allowed_users=anybody to $XWRAPPER (debconf path unavailable)"
    fi

    # Ensure needs_root_rights=yes is set. Append if missing, replace if present.
    if [ -f "$XWRAPPER" ] && grep -q '^needs_root_rights=' "$XWRAPPER"; then
        sed -i 's/^needs_root_rights=.*/needs_root_rights=yes/' "$XWRAPPER"
    else
        printf 'needs_root_rights=yes\n' >> "$XWRAPPER"
    fi
    echo "Ensured needs_root_rights=yes in $XWRAPPER"
fi

# Install stim2 service on first install only (never clobber existing config)
if [ ! -f /etc/systemd/system/stim2.service ] && [ ! -f /etc/systemd/system/stim2-x11.service ]; then
    cp /usr/local/stim2/systemd/$STIM2_SVC /etc/systemd/system/
    echo "Installed $STIM2_SVC (not enabled)"
    # /run/systemd/system only exists when systemd is the running init system.
    # Skip systemctl calls in build/CI containers where dbus/systemd aren't up.
    if [ -d /run/systemd/system ]; then
        systemctl daemon-reload
    fi
fi

# Bootstrap dlsh if not already installed
if [ ! -f /usr/local/dlsh/dlsh.zip ]; then
    echo "dlsh not found, installing..."
    DLSH_URL=$(curl -s https://api.github.com/repos/SheinbergLab/dlsh/releases/latest \
        | grep "browser_download_url.*dlsh.*\.zip" \
        | head -1 | cut -d'"' -f4)

    if [ -n "$DLSH_URL" ]; then
        DLSH_VER=$(curl -s https://api.github.com/repos/SheinbergLab/dlsh/releases/latest \
            | grep '"tag_name"' | head -1 | cut -d'"' -f4)
        mkdir -p /usr/local/dlsh
        curl -fSL "$DLSH_URL" -o /usr/local/dlsh/dlsh.zip
        echo "$DLSH_VER" > /usr/local/dlsh/VERSION
        echo "Installed dlsh $DLSH_VER to /usr/local/dlsh/"
    else
        echo "Warning: could not determine dlsh download URL"
    fi
fi

# Map dpkg arch to the asset arch slug used in SheinbergLab/dserv releases.
case "$ARCH" in
    amd64) AGENT_ARCH="amd64" ;;
    arm64) AGENT_ARCH="arm64" ;;
    *) AGENT_ARCH="" ;;
esac

# Bootstrap dserv-agent only on standalone stim2 systems (no dserv)
if [ -n "$AGENT_ARCH" ] \
   && ! dpkg -s dserv >/dev/null 2>&1 \
   && ! command -v dserv-agent >/dev/null 2>&1; then
    echo "dserv-agent not found (standalone stim2), installing..."

    AGENT_URL=$(curl -s https://api.github.com/repos/SheinbergLab/dserv/releases/latest \
        | grep "browser_download_url.*dserv-agent_linux_${AGENT_ARCH}" \
        | head -1 | cut -d'"' -f4)

    if [ -n "$AGENT_URL" ]; then
        curl -fSL "$AGENT_URL" -o /usr/local/bin/dserv-agent
        chmod +x /usr/local/bin/dserv-agent
        echo "Installed dserv-agent to /usr/local/bin/dserv-agent"

        if [ ! -f /etc/systemd/system/stim2-agent.service ]; then
            sed "s|__STIM2_SERVICE__|$STIM2_SVC_NAME|g" \
                /usr/local/stim2/systemd/stim2-agent.service \
                > /etc/systemd/system/stim2-agent.service
            if [ -d /run/systemd/system ]; then
                systemctl daemon-reload
                systemctl enable stim2-agent
                systemctl start stim2-agent
            fi
        fi
    else
        echo "Warning: could not determine dserv-agent download URL"
    fi
fi

# Bootstrap dservctl CLI from the same release. stim2-agent speaks the same
# HTTP/WS API as dserv-agent, so dservctl works against either; the stimctl
# shim below just wraps it for the local agent (default port 80).
if [ -n "$AGENT_ARCH" ] && ! command -v dservctl >/dev/null 2>&1; then
    echo "dservctl not found, installing..."
    DCTL_URL=$(curl -s https://api.github.com/repos/SheinbergLab/dserv/releases/latest \
        | grep "browser_download_url.*dservctl_linux_${AGENT_ARCH}" \
        | head -1 | cut -d'"' -f4)
    if [ -n "$DCTL_URL" ]; then
        curl -fSL "$DCTL_URL" -o /usr/local/bin/dservctl
        chmod +x /usr/local/bin/dservctl
        echo "Installed dservctl to /usr/local/bin/dservctl"
    else
        echo "Warning: could not determine dservctl download URL"
    fi
fi

# Convenience wrapper: dservctl pointed at the local stim2-agent (default
# port 80) and auto-loading the agent's bearer token when the caller has
# permission to read /etc/stim2-agent/env (typically only root). When the
# agent runs unauthenticated (no env file) the token is simply absent and
# the wrapper still works.
if [ -x /usr/local/bin/dservctl ] && [ ! -e /usr/local/bin/stimctl ]; then
    cat > /usr/local/bin/stimctl <<'EOF'
#!/bin/sh
# stimctl: dservctl pointed at the local stim2-agent (default port 80).
if [ -z "$DSERV_AGENT_TOKEN" ] && [ -r /etc/stim2-agent/env ]; then
    DSERV_AGENT_TOKEN=$(grep -m1 '^DSERV_AGENT_TOKEN=' /etc/stim2-agent/env | cut -d= -f2-)
    export DSERV_AGENT_TOKEN
fi
exec /usr/local/bin/dservctl "$@"
EOF
    chmod +x /usr/local/bin/stimctl
    echo "Installed stimctl wrapper to /usr/local/bin/stimctl"
fi
